        'Host': 'swea.riksbank.se:80', 
        'Accept-Encoding': 'gzip, deflate, br', 
        'Proxy-Connection': 'Keep-Alive'
      },
      data : da
    };

    axios(config)
    .then(function (response) {
      parser.parseString(response.data, function (err, result) {
          var base = result["SOAP-ENV:Envelope"]["SOAP-ENV:Body"][0]["ns0:getInterestAndExchangeRatesResponse"][0]["return"][0]["groups"][0]["series"]
          var njson = "";
          for (var i = 0; i < base.length; i++) {
            if (base[i].resultrows[0].value[0]["_"] == null) {
              continue;
            }
            
            let tempData = {
              "currency": base[i].seriesname[0]["_"].slice(base[i].seriesname[0]["_"].indexOf(" ")+1),
              "rate": Number(base[i].resultrows[0].value[0]["_"]) / Number(base[i].unit[0]["_"]),
              "date": new Date().toISOString()
            }
            documentRef.update({[tempData.currency]: tempData.rate});
            docRef.update({[tempData.currency]: tempData.rate});
            njson += JSON.stringify(tempData) + "\n"
          }
          resolve(njson)
      });
    })
    .catch(function (error) {
      console.log(error);
      reject(error);
    });
  });
